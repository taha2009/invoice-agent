PORT=8000
DEBUG=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=    # openssl rand -hex 32
WEBHOOK_BASE_URL=           # your Cloud Run service URL, e.g. https://your-service-xxxx-el.a.run.app
ALLOWED_TELEGRAM_IDS=       # comma-separated user IDs; leave blank to allow all

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GOOGLE_SHEET_ID=

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DATABASE=invoice_agent

# Session idle timeout in minutes — new conversation thread after this long inactive
SESSION_IDLE_MINUTES=30

INVOICE_PREFIX=2026-27

ISSUER_NAME=
ISSUER_DESIGNATION=
ISSUER_ADDRESS=
ISSUER_PHONE=
ISSUER_EMAIL=

BANK_BENEFICIARY=
BANK_NAME=
BANK_AC_TYPE=
BANK_AC_NUMBER=
BANK_IFSC=

# Signature image in GCS — leave blank to omit signature from PDF
GCS_BUCKET=
GCS_SIGNATURE_OBJECT=
