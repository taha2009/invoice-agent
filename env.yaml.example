TELEGRAM_BOT_TOKEN: "your-bot-token"
TELEGRAM_WEBHOOK_SECRET: "your-webhook-secret"
WEBHOOK_BASE_URL: "https://your-service-url.a.run.app"
ALLOWED_TELEGRAM_IDS: "123456789,987654321"  # comma-separated; remove to allow all

# WhatsApp (Meta Cloud API) — leave blank to disable
WHATSAPP_ACCESS_TOKEN: ""       # permanent system user token from Meta Business
WHATSAPP_PHONE_NUMBER_ID: ""    # Phone Number ID from WhatsApp Business API app
WHATSAPP_APP_SECRET: ""         # App Secret from Meta app dashboard (used to verify webhook signatures)
WHATSAPP_VERIFY_TOKEN: ""       # any secret string you set in the Meta webhook config
ALLOWED_WHATSAPP_NUMBERS: ""    # comma-separated E.164 numbers e.g. "919876543210,918800000000"; remove to allow all

GEMINI_API_KEY: "your-gemini-api-key"
GEMINI_MODEL: "gemini-2.0-flash"

GOOGLE_SHEET_ID: "your-sheet-id"

MONGODB_URI: "mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0"
MONGODB_DATABASE: "invoice_agent"

SESSION_IDLE_MINUTES: "30"

INVOICE_PREFIX: "2026-27"

ISSUER_NAME: "Your Name"
ISSUER_DESIGNATION: "Your Designation"
ISSUER_ADDRESS: "Your Office Address"
ISSUER_PHONE: "+91 XXXXX XXXXX"
ISSUER_EMAIL: "your@email.com"

BANK_BENEFICIARY: "Your Name"
BANK_NAME: "Your Bank"
BANK_AC_TYPE: "Current"
BANK_AC_NUMBER: "XXXXXXXXXXXX"
BANK_IFSC: "XXXX0000000"

# Signature image in GCS — leave blank to omit signature from PDF
GCS_BUCKET: ""
GCS_SIGNATURE_OBJECT: ""
